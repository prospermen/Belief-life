# ---- AI API (Node backend) ----
# Cloud platforms usually inject PORT automatically.
PORT=8787
AI_API_PORT=8787
HOST=0.0.0.0

# Set true for backend-only deployment (do not serve Vite dist static files)
API_ONLY=true

# CORS allowlist. In production set this to your frontend domain.
AI_ALLOW_ORIGIN=*

AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
OPENAI_MODEL=deepseek-chat
OPENAI_BASE_URL=https://api.deepseek.com

# Frontend direct API base (used in separated deployment)
VITE_AI_API_BASE_URL=http://localhost:8787

# Optional compatibility var
# OPENAI_API_KEY=your_api_key

# Local debug switch
MOCK_AI=false
